# ─────────────────────────────────────────────────────────────────
# TECHÁ — .env.example  |  Copie para .env e preencha os valores
# NUNCA commitar o arquivo .env no Git
# ─────────────────────────────────────────────────────────────────

# Aplicação
APP_NAME=Techá
APP_ENV=development          # development | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=TROQUE_POR_UM_SEGREDO_LONGO_E_ALEATORIO_AQUI

# Banco de Dados PostgreSQL + PostGIS
DATABASE_URL=postgresql+asyncpg://techa_user:techa_pass@localhost:5432/techa_db
DATABASE_URL_SYNC=postgresql://techa_user:techa_pass@localhost:5432/techa_db

# Redis (fila de processamento)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=OUTRO_SEGREDO_DIFERENTE_DO_APP_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30

# Copernicus / Sentinel-2
COPERNICUS_CLIENT_ID=seu_client_id_aqui
COPERNICUS_CLIENT_SECRET=seu_client_secret_aqui
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
SENTINEL_STAC_URL=https://catalogue.dataspace.copernicus.eu/stac

# Storage local (Sprint 1)
TILES_STORAGE_PATH=/data/tiles
RASTER_STORAGE_PATH=/data/rasters

# Firebase Cloud Messaging (preencher no Sprint 2)
FIREBASE_CREDENTIALS_PATH=

# Scheduler
SENTINEL_CHECK_INTERVAL_MINUTES=30
CLOUD_COVER_THRESHOLD=20.0
NDVI_DROP_THRESHOLD=15.0
