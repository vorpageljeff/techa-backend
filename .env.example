# ─────────────────────────────────────────────────────────────────
# TECHÁ — .env.example  |  Copie para .env e preencha os valores
# NUNCA commitar o arquivo .env no Git
# ─────────────────────────────────────────────────────────────────

# Aplicação
APP_NAME=Techá
APP_ENV=development          # development | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=TROQUE_POR_UM_SEGREDO_LONGO_E_ALEATORIO_AQUI

# Banco de Dados PostgreSQL + PostGIS
DATABASE_URL=postgresql+asyncpg://techa_user:techa_pass@localhost:5432/techa_db
DATABASE_URL_SYNC=postgresql://techa_user:techa_pass@localhost:5432/techa_db

# Redis (fila de processamento)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=OUTRO_SEGREDO_DIFERENTE_DO_APP_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30

# Copernicus / Sentinel-2
# OBRIGATÓRIO para download de imagens: conta pessoal em dataspace.copernicus.eu
COPERNICUS_USER=seu_email@dominio.com
COPERNICUS_PASSWORD=sua_senha_cdse
# Opcionais (service account sh-*) — só funcionam para busca STAC, NÃO para download
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
SENTINEL_STAC_URL=https://catalogue.dataspace.copernicus.eu/stac

# Storage local (Sprint 1)
TILES_STORAGE_PATH=/data/tiles
RASTER_STORAGE_PATH=/data/rasters

# Firebase Cloud Messaging
# Opção 1 (local dev): caminho para o JSON da service account do Firebase
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# Opção 2 (produção/Railway): conteúdo do JSON em base64 (evita arquivo no container)
FIREBASE_CREDENTIALS_BASE64=

# Email (Gmail SMTP — reset de senha)
GMAIL_USER=suporte@innovagropy.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx   # Senha de App Google (não a senha normal)

# Scheduler
SENTINEL_CHECK_INTERVAL_MINUTES=30
CLOUD_COVER_THRESHOLD=20.0
NDVI_DROP_THRESHOLD=15.0
